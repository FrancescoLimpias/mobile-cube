{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MobileCube Dist",
            "type": "shell",
            "command": "docker compose run --rm dev python3 build.py",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Start Dev Server",
            "type": "shell",
            "command": "docker compose up dev",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "isBackground": true,
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Test Story",
            "type": "shell",
            "command": "docker compose run --rm dev bash -c 'cd test-story && bash build.sh'",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
