{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build MobileCube Dist",
            "type": "shell",
            "command": "task build",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Start Dev Server",
            "type": "shell",
            "command": "task dev",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "isBackground": true,
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Test Story",
            "type": "shell",
            "command": "task build-test",
            "options": {
                "cwd": "${workspaceFolder}/mobile-cube"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
