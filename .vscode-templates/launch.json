{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build MobileCube Dist",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "docker",
            "args": [
                "compose",
                "run",
                "--rm",
                "dev",
                "python3",
                "build.py"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        },
        {
            "name": "Start Dev Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "docker",
            "args": [
                "compose",
                "up",
                "dev"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        },
        {
            "name": "Build Test Story",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "docker",
            "args": [
                "compose",
                "run",
                "--rm",
                "dev",
                "bash",
                "-c",
                "cd test-story && bash build.sh"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        }
    ]
}
