{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Build MobileCube Dist",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "task",
            "args": [
                "build"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        },
        {
            "name": "Start Dev Server",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "task",
            "args": [
                "dev"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        },
        {
            "name": "Build Test Story",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "task",
            "args": [
                "build-test"
            ],
            "cwd": "${workspaceFolder}/mobile-cube",
            "console": "integratedTerminal",
            "noDebug": true
        }
    ]
}
