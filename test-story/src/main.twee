:: StoryTitle
MobileCube Test Story

:: StoryData
{
  "ifid": "A41865E5-CFEB-4D99-AABB-2A214FF06D5E",
  "format": "MobileCube",
  "format-version": "0.1.0",
  "start": "Start"
}

:: Start
<div class="test-container">
  <h1>Welcome to MobileCube!</h1>
  <p>This is a sample story testing the features of the MobileCube format.</p>
  <<set $apples to 0>>
  <p>Variables test: You have $apples apples.</p>
  
  <p>Inline Button Support:</p>
  <<button "Go to Scene 1" "Scene 1">><</button>>
  
  <p>Standard Link Support:</p>
  [[Go to Scene 1 (Link)|Scene 1]]
</div>

:: Scene 1
<div class="test-container">
  <h1>Scene 1</h1>
  <p>You have navigated to the first scene successfully.</p>
  <<set $apples to $apples + 1>>
  <<if $apples gt 0>>
    <p>Conditional test passed! Apples: $apples</p>
  <<else>>
    <p>Conditional test failed. Apples: $apples</p>
  <</if>>
  
  <<button "Go Back" "Start">><</button>>
  <p id="js-demo">JS will update this text if custom scripts are loaded correctly.</p>
</div>
